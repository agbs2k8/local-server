# Example environment configuration
# Copy this to .env and configure your settings

# Application settings
APP_NAME=trmnl-agent
LOG_LEVEL=INFO
KUBE_CONTEXT=legion-controller
NAMESPACE=default
PULL_RETRY=3
IMAGE_REPOSITORY=trmnl-agent
TARGET_PLATFORM=linux/amd64
RUN_POST_DEPLOY_JOB=false

# Destination Webhook URL for forwarding data
WEBHOOK_URL=https://your-webhook-endpoint.com

# Where we're extract the data from 
SOURCE_URL=https://www.accuweather.com/en/us/lakeville/55044/sinus-weather/2247734

# Optional overrides for the daily 05:00 Central Time schedule
# CRON_SCHEDULE=0 5 * * *
# CRON_TIME_ZONE=America/Chicago