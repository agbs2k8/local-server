# Pi-hole Environment Variables
# Copy this file to .env and customize the values
# IMPORTANT: Quote values that contain special characters like semicolons

# Timezone - Set to your local timezone
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ="America/New_York"

# Admin password for Pi-hole web interface
# Leave empty for a random password (check logs with: kubectl logs <pod> | grep "random password")
FTLCONF_webserver_api_password="secure-admin-password"

# DNS listening mode - should be 'ALL' for Kubernetes deployments
FTLCONF_dns_listeningMode="ALL"

# Upstream DNS servers (semicolon separated) - MUST be quoted
# Examples: "8.8.8.8;8.8.4.4" or "1.1.1.1;1.0.0.1" or "9.9.9.9;149.112.112.112"
FTLCONF_dns_upstreams="8.8.8.8;8.8.4.4"

# Optional: Enable DNSSEC validation
FTLCONF_dns_dnssec="true"

# Optional: DNS query logging
FTLCONF_dns_queryLogging="true"

# Optional: Privacy level (0=show everything, 1=hide domains, 2=hide domains and clients, 3=anonymous mode)
FTLCONF_dns_privacyLevel="0"

# Pi-hole user and group IDs (should match your cluster's security context)
PIHOLE_UID="1000"
PIHOLE_GID="1000"

# Optional: Custom blocking page behavior
FTLCONF_webserver_api_piholeBlockingMode="NULL_BLOCK_MODE"

# Optional: Rate limiting (requests per minute per client)
FTLCONF_dns_rateLimit="1000/60"

# Optional: Additional packages to install (space separated)
# ADDITIONAL_PACKAGES="nano vim curl"

# Optional: Custom FTL command options
# FTL_CMD="no-daemon -- --dns-forward-max 300"